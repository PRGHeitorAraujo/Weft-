VITE_API_URL=http://localhost:8000

# Static demo mode is the DEFAULT (any value other than the literal string
# "false" — including the variable being unset entirely, e.g. a Vercel
# project misconfigured to not inject it — turns it on). In demo mode the
# app reads the 3 example profiles from frontend/src/demo-data/*.json
# instead of calling the backend, skips login (profile picker instead), and
# disables all write actions — VITE_API_URL is ignored. Set to "false"
# explicitly for local dev against the real backend (already done in
# frontend/.env). See README's "Demo estático" section.
VITE_DEMO_MODE=false
