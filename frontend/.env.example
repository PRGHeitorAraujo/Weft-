VITE_API_URL=http://localhost:8000

# Static demo mode: when "true", the app reads the 3 example profiles from
# frontend/src/demo-data/*.json instead of calling the backend, skips login
# (profile picker instead), and disables all write actions. VITE_API_URL is
# ignored in this mode. See README's "Demo estático" section.
VITE_DEMO_MODE=false
