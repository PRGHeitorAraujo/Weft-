    {
      "id": "07d40893-b3b1-4d22-975a-c422b7881b68",
      "book_id": "3d2915cc-e866-4151-b68b-4c5cb28f0e86",
      "chapter_id": "14898897-f6cc-4937-8191-71f72491e797",
      "title": "O tribunal julga o caráter, não o ato",
      "body": "O julgamento de Meursault gira em torno do café no velório da mãe, não do tiro. A moral pública precisa de uma narrativa, não de um fato.",
      "kind": "observacao",
