    {
      "id": "3cbfeb08-44c1-4d13-974f-7356c40df767",
      "book_id": "18e4c263-be3b-4de9-adbf-9e5843023a27",
      "chapter_id": "19d9961b-eeaf-4884-8b68-0e300daa72ef",
      "title": "Porfiri não é consciência benevolente",
      "body": "A leitura comum trata Porfiri como guia moral. Discordo: é coerção psicológica com método — o Estado terceirizando a confissão.",
      "kind": "discordancia",
