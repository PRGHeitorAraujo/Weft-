    {
      "id": "2f5ddf4b-26e6-4054-8d44-9d8e46baedb6",
      "book_id": "18e4c263-be3b-4de9-adbf-9e5843023a27",
      "chapter_id": "7cd45416-fdfc-4f2f-8607-7bad6d3b0aca",
      "title": "O castigo começa antes do crime",
      "body": "A angústia dos dias que antecedem o assassinato sugere que o castigo do título não é a Sibéria — é a consciência antecipando a pena.",
      "kind": "hipotese",
