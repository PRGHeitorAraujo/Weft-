    },
    {
      "id": "1cff3cda-7c46-4c15-a3de-17efd76a8c57",
      "book_id": "18e4c263-be3b-4de9-adbf-9e5843023a27",
      "chapter_id": "5f2f0b52-a523-4187-bffd-d0f3d3fafe6f",
      "title": "Sônia carrega a culpa dos outros",
      "body": "Sônia sofre sem ter culpa própria; a compaixão dela funciona como pré-condição para a confissão de Raskólnikov. Ninguém confessa ao vazio.",
      "kind": "hipotese",
      "free_tags": [],
