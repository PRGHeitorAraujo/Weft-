    {
      "id": "1c2ab069-323d-4c64-9830-f0ede532cbc7",
      "book_id": "0b0bbd7c-0090-4842-8fc9-ec33362b6a0f",
      "chapter_id": "e7543319-a5dd-459b-91ff-4565e1717f80",
      "title": "Culpa sem acusador é infinita?",
      "body": "Quando ninguém formula a acusação, a defesa nunca termina. A culpa sem lei seria mais pesada que a culpa com sentença?",
      "kind": "pergunta",
      "free_tags": [],
      "created_at": "2026-07-02T14:22:45.583182+00:00",
      "themes": [
